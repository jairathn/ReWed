# ── Database (auto-set by Vercel Neon integration) ──
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host/db?sslmode=require

# ── Storage (Cloudflare R2 — needed for photo uploads, Phase 2) ──
R2_ACCOUNT_ID=abc123
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=wedding-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Auth (generate with: openssl rand -hex 32) ──
JWT_SECRET=change-me-to-64-char-random-hex-in-production
GUEST_SESSION_SECRET=change-me-to-64-char-random-hex-in-production

# ── AI (Phase 2 — needed for portraits) ──
OPENAI_API_KEY=sk-...

# ── Billing (optional — mock payments used when not set) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Email (legacy SES, optional) ──
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=xxx
SES_SECRET_ACCESS_KEY=xxx
SES_FROM_EMAIL=hello@yourplatform.com

# ── Email (Resend — used for dashboard guest broadcasts) ──
# Sign up at https://resend.com (free tier: 3,000/month, 100/day).
# Requires a verified sender domain; you cannot send directly from a Gmail
# address. Verify jaywalkingtojairath.wedding in the Resend dashboard, then:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@jaywalkingtojairath.wedding
RESEND_FROM_NAME=Shriya & Neil
# Replies go here — use the couple's Gmail so responses land in their inbox:
RESEND_REPLY_TO=shriyaneilwedding@gmail.com

# ── SMS (Phase 4) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Cache (Upstash Redis — use REST URL and token from dashboard) ──
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
TEST_MODE=true
